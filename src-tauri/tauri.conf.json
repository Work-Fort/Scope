{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "WorkFort",
  "version": "0.1.0",
  "identifier": "com.workfort.app",
  "build": {
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../web/shell" },
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../web/shell" },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/shell/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ws://localhost:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "windows": [
      {
        "title": "WorkFort",
        "width": 1024,
        "height": 768,
        "minWidth": 375,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
