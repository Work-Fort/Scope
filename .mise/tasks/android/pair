#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Pair with an Android device over wireless debugging"
set -euo pipefail

ADB="$(mise where android-sdk)/platform-tools/adb"

echo "On your phone:"
echo "  1. Settings → Developer Options → Wireless debugging"
echo "  2. Tap 'Pair device with pairing code'"
echo "  3. Enter the IP:PORT and PIN below"
echo ""
read -rp "IP:PORT (e.g. 192.168.1.100:12345): " PAIR_ADDR
read -rp "PIN (e.g. 123456): " PAIR_PIN

"$ADB" pair "$PAIR_ADDR" "$PAIR_PIN"

echo ""
echo "Paired! Now look at the main 'IP address & Port' on the Wireless debugging screen."
read -rp "IP:PORT to connect (e.g. 192.168.1.100:54321): " CONNECT_ADDR

"$ADB" connect "$CONNECT_ADDR"
echo ""
echo "==> Connected. Run 'mise run android:install' to deploy."
