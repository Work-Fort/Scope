#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Install the debug APK on a connected Android device"
set -euo pipefail

ADB="$(mise where android-sdk)/platform-tools/adb"
APK="src-tauri/gen/android/app/build/outputs/apk/universal/debug/app-universal-debug.apk"

if [ ! -f "$APK" ]; then
  echo "APK not found. Run 'mise run android:build' first." >&2
  exit 1
fi

DEVICES=$("$ADB" devices | grep -v "List of devices" | grep -v "^$" | wc -l)
if [ "$DEVICES" -eq 0 ]; then
  echo "No device connected. Run 'mise run android:pair' first." >&2
  exit 1
fi

echo "==> Installing $APK..."
"$ADB" install -r "$APK"
echo "==> Done."
