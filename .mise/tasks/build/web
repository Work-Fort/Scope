#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Build shell SPA and stage for Go embed"
set -euo pipefail

if [ ! -d "web/shell/node_modules" ]; then
  echo "Run 'cd web && pnpm install' first" >&2
  exit 1
fi

echo "Building shell SPA..."
(cd web/shell && pnpm build)

echo "Staging SPA for Go embed..."
rm -rf cmd/web/dist
cp -r web/shell/dist cmd/web/dist

echo "✓ Shell SPA staged at cmd/web/dist"
