#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Build a static release binary"
#MISE sources=["**/*.go", "go.mod", "go.sum"]
#MISE outputs=["build/workfort"]
set -euo pipefail

mkdir -p build
: ${VERSION:=$(git rev-parse --short HEAD 2>/dev/null || echo "dev")}
CGO_ENABLED=0 go build -trimpath -ldflags "-s -w -X github.com/Work-Fort/Scope/cmd.Version=${VERSION}" -o build/workfort .
echo "✓ Release build complete"
