#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Install release binary to ~/.local/bin"
#MISE depends=["build:release"]
set -euo pipefail

INSTALL_DIR="$HOME/.local/bin"
if [ ! -d "$INSTALL_DIR" ]; then
    echo "Error: $INSTALL_DIR does not exist"
    exit 1
fi
if ! echo "$PATH" | tr ':' '\n' | grep -qx "$INSTALL_DIR"; then
    echo "Error: $INSTALL_DIR is not on PATH"
    exit 1
fi
cp build/workfort "$INSTALL_DIR/workfort"
echo "✓ Installed workfort to $INSTALL_DIR"
